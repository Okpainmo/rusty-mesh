MESH_BASE_URL=http://127.0.0.1:3080/api/v1/mesh
MESH_TOKEN=local-demo-mesh-token

K6_WARMUP_DURATION=30s
K6_WARMUP_VUS=5
K6_STEADY_DURATION=2m
K6_TARGET_VUS=30
K6_COOLDOWN_DURATION=30s
K6_MAX_FAILURE_RATE=0.05
K6_P95_MS=500
K6_SLEEP_SECONDS=1

K6_SERVICE_PREFIX=k6-orders
K6_SERVICE_VERSION=1.2.3
K6_SERVICE_VERSION_REQUIREMENT=^1.0.0
K6_INTERNAL_HOST=
K6_EXTERNAL_HOST=127.0.0.1
K6_EXTERNAL_SCHEME=http

# Optional. Leave empty to derive ports per virtual user.
# K6_EXTERNAL_PORT=43001
